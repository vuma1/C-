<UserControl x:Class="QuanLyQuanCafe.Views.TableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#4E342E" Padding="15,10">
            <TextBlock Text="QUẢN LÝ BÀN" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Input Form - Đặt ở dưới cùng -->
        <Border DockPanel.Dock="Bottom" Background="White" CornerRadius="5" Padding="15" Margin="20,10,20,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtName" Width="300" Height="35" Style="{StaticResource InputFieldStyle}" 
                         VerticalContentAlignment="Center"/>
                
                <Button Content="➕ Thêm" Margin="30,0,0,0" Click="HandleAdd" Style="{StaticResource AddButtonStyle}"/>
                <Button Content="✏ Sửa" Margin="10,0,0,0" Click="HandleEdit" Style="{StaticResource EditButtonStyle}"/>
                <Button Content="🗑 Xóa" Margin="10,0,0,0" Click="HandleDelete" Style="{StaticResource DeleteButtonStyle}"/>
                <Button Content="🔄 Mới" Margin="10,0,0,0" Click="HandleClear" Style="{StaticResource ClearButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Table List Card - Chiếm hết không gian còn lại -->
        <Border Background="White" CornerRadius="5" Padding="15" Margin="20,20,20,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Danh Sách Bàn" FontSize="14" FontWeight="Bold" Foreground="#666" Margin="0,0,0,10"/>
                
                <DataGrid x:Name="tableList" 
                          ItemsSource="{Binding Tables}"
                          Style="{StaticResource ModernDataGridStyle}"
                          SelectionChanged="OnTableSelected">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Bàn" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
