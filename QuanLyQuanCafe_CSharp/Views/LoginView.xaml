<Window x:Class="QuanLyQuanCafe.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - IDK Coffee" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- BÊN TRÁI: Branding Panel -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#3E2723" Offset="0"/>
                    <GradientStop Color="#5D4037" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo Icon -->
                <TextBlock Text="☕" FontSize="60" Foreground="#D7CCC8" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="10"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <!-- Tên quán -->
                <TextBlock Text="IDK Coffee" FontSize="28" FontWeight="Bold" Foreground="#EFEBE9" 
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- BÊN PHẢI: Form đăng nhập -->
        <Border Grid.Column="1" Background="#F3E5F5" Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                
                <!-- Title -->
                <TextBlock Text="Đăng nhập" FontSize="28" FontWeight="Bold" Foreground="#4E342E" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Nhập thông tin tài khoản của bạn" FontSize="13" Foreground="#8D6E63" 
                           HorizontalAlignment="Center" Margin="0,5,0,25"/>
                
                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" FontSize="13" FontWeight="Bold" Foreground="#5D4037" Margin="0,0,0,8"/>
                <TextBox x:Name="txtUser" Height="40" Padding="12,10" FontSize="14"
                         Background="White" BorderBrush="#BCAAA4" BorderThickness="1"/>
                
                <!-- Password -->
                <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="Bold" Foreground="#5D4037" Margin="0,20,0,8"/>
                <PasswordBox x:Name="txtPass" Height="40" Padding="12,10" FontSize="14"
                             Background="White" BorderBrush="#BCAAA4" BorderThickness="1"/>
                
                <!-- Error Label -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontSize="12" TextWrapping="Wrap" 
                           Margin="0,15,0,0" MaxWidth="320"/>
                
                <!-- Login Button -->
                <Button Content="ĐĂNG NHẬP" Height="45" Margin="0,20,0,0" Click="HandleLogin"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                
            </StackPanel>
        </Border>
    </Grid>
</Window>
