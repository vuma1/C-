<Window x:Class="QuanLyQuanCafe.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Quán Cafe" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar (trái) -->
        <Border Grid.Column="0" Background="#3E2723">
            <DockPanel>
                <!-- Logo Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="☕" FontSize="28" Foreground="#D7CCC8" VerticalAlignment="Center"/>
                        <TextBlock Text="IDK Coffee" FontSize="20" FontWeight="Bold" Foreground="#EFEBE9" 
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Logout Button (dưới) -->
                <Button x:Name="btnLogout" Content="⬅ Đăng xuất" DockPanel.Dock="Bottom" 
                        Style="{StaticResource MenuButtonStyle}" Click="HandleExit" Margin="0,0,0,20"/>

                <!-- Menu Items -->
                <StackPanel>
                    <Button x:Name="btnSale" Content="☕  Bán hàng" Style="{StaticResource MenuButtonStyle}" Click="OpenOrderScreen"/>
                    <Button x:Name="btnTable" Content="🍽  Quản lý Bàn" Style="{StaticResource MenuButtonStyle}" Click="OpenTableScreen"/>
                    <Button x:Name="btnProduct" Content="🍔  Sản phẩm" Style="{StaticResource MenuButtonStyle}" Click="OpenProductScreen"/>
                    <Button x:Name="btnStats" Content="📈  Thống kê" Style="{StaticResource MenuButtonStyle}" Click="OpenStatsScreen"/>
                    <Button x:Name="btnUsers" Content="👥  Nhân viên" Style="{StaticResource MenuButtonStyle}" Click="OpenUserScreen"/>
                    <Button x:Name="btnFeedback" Content="★  Đánh giá" Style="{StaticResource MenuButtonStyle}" Click="OpenFeedbackScreen"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content (phải) -->
        <Border Grid.Column="1" Background="#F3E5F5">
            <DockPanel>
                <!-- Welcome Bar -->
                <Border DockPanel.Dock="Top" Background="#EDE7F6" Padding="15,10">
                    <TextBlock x:Name="lblWelcome" Text="Xin chào!" FontSize="14" FontWeight="Bold" Foreground="#5D4037"/>
                </Border>

                <!-- Content Area -->
                <Border x:Name="contentArea" Background="#F3E5F5">
                    <TextBlock Text="Chọn chức năng từ menu bên trái" FontSize="16" Foreground="#888888" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</Window>
