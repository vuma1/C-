<UserControl x:Class="QuanLyQuanCafe.Views.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#4E342E" Padding="15,10">
            <TextBlock Text="MÀN HÌNH BÁN HÀNG" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Main Content -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Menu sản phẩm -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,5,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="THỰC ĐƠN" FontSize="16" FontWeight="Bold" Foreground="#6F4E37" Margin="0,0,0,10"/>
                    
                    <!-- Product list -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Số lượng:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtQuantity" Text="1" Width="60" TextAlignment="Center" Style="{StaticResource InputFieldStyle}"/>
                        <Button Content="Thêm vào Bill >>" Margin="10,0,0,0" Click="HandleAddToCart"
                                Background="#6F4E37" Foreground="White" Padding="15,8" Cursor="Hand"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="productContainer" Orientation="Horizontal"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- RIGHT: Bàn + Hóa đơn -->
            <Border Grid.Column="1" Background="White" Margin="5,0,0,0">
                <DockPanel>
                    <!-- Chọn bàn -->
                    <Border DockPanel.Dock="Top" Padding="15">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Chọn bàn phục vụ:" FontSize="16" FontWeight="Bold" Foreground="#D84315"/>
                                <TextBlock x:Name="lblSelectedTableName" Text="Chưa chọn bàn" Foreground="#D84315" 
                                           FontWeight="Bold" HorizontalAlignment="Right"/>
                            </DockPanel>
                            
                            <WrapPanel x:Name="tableContainer" Orientation="Horizontal" Margin="0,10,0,10"/>
                            
                            <!-- Chú thích -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Chú thích:" FontSize="11" Foreground="#777" Margin="0,0,15,0"/>
                                <Border Width="15" Height="15" Background="White" BorderBrush="#4E342E" BorderThickness="1" CornerRadius="4"/>
                                <TextBlock Text="Trống" FontSize="11" Margin="5,0,15,0"/>
                                <Border Width="15" Height="15" Background="#E0E0E0" CornerRadius="4"/>
                                <TextBlock Text="Có khách" FontSize="11" Margin="5,0,15,0"/>
                                <Border Width="15" Height="15" Background="#4E342E" CornerRadius="4"/>
                                <TextBlock Text="Đang chọn" FontSize="11" FontWeight="Bold" Foreground="#4E342E" Margin="5,0,0,0"/>
                                <Button Content="🔓 Trả bàn" Margin="20,0,0,0" Click="HandleFreeTable"
                                        Background="#17a2b8" Foreground="White" FontWeight="Bold" Padding="10,5" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Hóa đơn -->
                    <Border Padding="15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Hóa đơn tạm tính" FontSize="14" FontWeight="Bold" Foreground="#D84315" Margin="0,0,0,10"/>
                            
                            <!-- Buttons và tổng tiền -->
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="🗑 Xóa món" Click="HandleRemoveItem"
                                        Background="#dc3545" Foreground="White" FontWeight="Bold" Padding="10,8" Cursor="Hand"/>
                                <Button Content="❌ Xóa tất cả" Click="HandleClearOrder" Margin="10,0,0,0"
                                        Background="#6c757d" Foreground="White" FontWeight="Bold" Padding="10,8" Cursor="Hand"/>
                                <TextBlock Text="TỔNG TIỀN:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="30,0,10,0"/>
                                <TextBlock x:Name="lblTotalAmount" Text="0 VNĐ" FontSize="18" FontWeight="Bold" Foreground="#D84315" VerticalAlignment="Center"/>
                                <Button Content="💳 Thanh Toán" Click="HandleCheckout" Margin="20,0,0,0"
                                        Background="#28a745" Foreground="White" FontSize="14" FontWeight="Bold" Padding="15,8" Cursor="Hand"/>
                            </StackPanel>

                            <!-- DataGrid hóa đơn -->
                            <DataGrid x:Name="orderTable" 
                                      Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên Món" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="60"/>
                                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="120"/>
                                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
