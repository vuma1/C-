<UserControl x:Class="QuanLyQuanCafe.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3E5F5">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#4E342E" Padding="15,10">
            <TextBlock Text="BÁO CÁO THỐNG KÊ DOANH THU" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Tab đơn -->
        <Border DockPanel.Dock="Top" Background="#EEEEEE" Padding="10,5">
            <TextBlock Text="📊 Doanh thu theo Ngày (30 ngày gần nhất)" 
                       FontSize="14" FontWeight="SemiBold" Foreground="#4CAF50" 
                       Padding="15,8"/>
        </Border>

        <!-- Content -->
        <Border Margin="20" Background="White" CornerRadius="8" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="2"/>
            </Border.Effect>
            
            <DockPanel>
                <!-- Tiêu đề -->
                <TextBlock x:Name="txtChartTitle" DockPanel.Dock="Top" Text="Biểu đồ doanh thu từng ngày" 
                           FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>
                
                <!-- Chart Title -->
                <TextBlock x:Name="txtChartSubTitle" DockPanel.Dock="Top" Text="Doanh Thu Theo Ngày" 
                           FontSize="18" FontWeight="Bold" Foreground="#333" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <!-- Nhãn trục X -->
                <TextBlock DockPanel.Dock="Bottom" Text="Ngày" 
                           FontSize="14" FontWeight="SemiBold" Foreground="#666" 
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                
                <!-- Vùng biểu đồ với trục Y -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Trục Y (nhãn giá trị) -->
                    <Grid x:Name="yAxisLabels" Grid.Column="0" Grid.Row="0">
                        <!-- Y-axis labels sẽ được tạo bằng code -->
                    </Grid>
                    
                    <!-- Nhãn "Doanh thu (VNĐ)" dưới trục Y -->
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Doanh thu (VNĐ)" 
                               FontSize="10" FontWeight="SemiBold" Foreground="#666"
                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/>
                    
                    <!-- Vùng biểu đồ chính -->
                    <Border Grid.Column="1" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="1,0,0,1">
                        <Grid x:Name="chartArea">
                            <!-- Grid lines -->
                            <Canvas x:Name="gridLinesCanvas"/>
                            
                            <!-- Các cột biểu đồ -->
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="chartDaily" VerticalAlignment="Bottom" Margin="10,0,10,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                <StackPanel Width="180" Margin="10,0" VerticalAlignment="Bottom">
                                                <!-- Cột biểu đồ màu cam -->
                                                <Border Background="#FF7043" Height="{Binding BarHeight}" 
                                                        Width="120" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    
                    <!-- Nhãn ngày ở dưới biểu đồ -->
                    <ScrollViewer Grid.Column="1" Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="chartLabels" Margin="10,0,10,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" Width="200" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" TextAlignment="Center" Foreground="#333"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
